---
/**
 * Animated cartoon "Claude CEO" mascot. Five states, switched by
 * `data-state` on #mascot (driven from scripts/detect.ts):
 *   doze   – default, asleep (Zzz bubbles)
 *   search – scanning with a magnifying glass
 *   low    – smiling thumbs-up
 *   medium – suspicious stare
 *   high   – pointing a (toy) gun at you
 * Every state loops a CSS animation so the character is never static.
 */
const STATES = [
  { id: 'doze', src: '/mascot/ceo-doze.webp' },
  { id: 'search', src: '/mascot/ceo-search.webp' },
  { id: 'low', src: '/mascot/ceo-happy.webp' },
  { id: 'medium', src: '/mascot/ceo-suspect.webp' },
  { id: 'high', src: '/mascot/ceo-gun.webp' },
];
---

<div class="mascot" id="mascot" data-state="doze" aria-hidden="true">
  <div class="mascot__stage">
    <div class="mascot__lead">
      {STATES.map((s) => <img class="mascot__fig" data-mstate={s.id} src={s.src} alt="" decoding="async" />)}
      <span class="mascot__zzz"><i>Z</i><i>Z</i><i>Z</i></span>
    </div>
    <img class="mascot__trump" src="/mascot/trump-fired.webp" alt="" decoding="async" />
  </div>
  <span class="mascot__shadow"></span>
</div>

<style>
  .mascot {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 232px;
    flex: none;
    transition: width 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mascot[data-reaction='true'] {
    width: 372px;
  }
  .mascot__stage {
    position: relative;
    height: 248px;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    isolation: isolate;
  }
  .mascot__lead {
    position: relative;
    z-index: 2;
    width: 210px;
    height: 238px;
    margin-right: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    transition: margin-right 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mascot[data-reaction='true'] .mascot__lead {
    margin-right: -12px;
  }
  .mascot__fig {
    display: none;
    height: 232px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    transform-origin: 50% 85%;
    will-change: transform;
  }
  .mascot__trump {
    display: none;
    z-index: 1;
    height: 218px;
    width: auto;
    max-width: 44%;
    margin-left: -6px;
    object-fit: contain;
    filter: drop-shadow(0 14px 22px rgba(36, 28, 12, 0.18));
    transform-origin: 50% 87%;
    animation: trump-idle 2.4s ease-in-out infinite;
    will-change: transform;
  }
  .mascot[data-reaction='true'] .mascot__trump {
    display: block;
    animation:
      trump-enter 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      trump-idle 2.4s ease-in-out 0.4s infinite;
  }
  .mascot__shadow {
    width: 128px;
    height: 15px;
    border-radius: 50%;
    background: rgba(31, 30, 29, 0.13);
    filter: blur(3px);
    margin-top: -5px;
    transition:
      width 0.34s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.34s ease;
  }
  .mascot[data-reaction='true'] .mascot__shadow {
    width: 250px;
    background:
      radial-gradient(ellipse at 38% 50%, rgba(31, 30, 29, 0.15), transparent 68%),
      radial-gradient(ellipse at 66% 50%, rgba(31, 30, 29, 0.12), transparent 66%);
  }

  /* ---- state visibility + loops (pop first, then the idle loop) ---- */
  .mascot[data-state='doze'] .mascot__fig[data-mstate='doze'] {
    display: block;
    animation:
      mascot-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      mascot-doze 3.8s ease-in-out 0.32s infinite;
  }
  .mascot[data-state='search'] .mascot__fig[data-mstate='search'] {
    display: block;
    animation:
      mascot-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      mascot-search 1.9s ease-in-out 0.32s infinite;
  }
  .mascot[data-state='low'] .mascot__fig[data-mstate='low'] {
    display: block;
    animation:
      mascot-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      mascot-happy 0.95s ease-in-out 0.32s infinite;
  }
  .mascot[data-state='medium'] .mascot__fig[data-mstate='medium'] {
    display: block;
    animation:
      mascot-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      mascot-suspect 3s ease-in-out 0.32s infinite;
  }
  .mascot[data-state='high'] .mascot__fig[data-mstate='high'] {
    display: block;
    animation:
      mascot-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      mascot-gun 0.45s linear 0.32s infinite;
  }
  .mascot[data-reaction='true'][data-state='search'] .mascot__trump {
    animation: trump-scan 1.9s ease-in-out infinite;
  }
  .mascot[data-reaction='true'][data-state='low'] .mascot__trump {
    animation: trump-approve 1.1s ease-in-out infinite;
  }
  .mascot[data-reaction='true'][data-state='medium'] .mascot__trump {
    animation: trump-judge 1.8s ease-in-out infinite;
  }
  .mascot[data-reaction='true'][data-state='high'] .mascot__trump {
    animation: trump-fire 0.46s linear infinite;
  }

  /* ---- Zzz bubbles, doze only ---- */
  .mascot__zzz {
    display: none;
    position: absolute;
    top: 14px;
    right: 26px;
    width: 40px;
    height: 40px;
    pointer-events: none;
  }
  .mascot[data-state='doze'] .mascot__zzz {
    display: block;
  }
  .mascot__zzz i {
    position: absolute;
    right: 6px;
    bottom: 0;
    font-style: normal;
    font-family: var(--serif);
    font-weight: 700;
    color: var(--muted-2);
    opacity: 0;
    animation: mascot-zzz 2.7s ease-out infinite;
  }
  .mascot__zzz i:nth-child(1) {
    font-size: 0.9rem;
  }
  .mascot__zzz i:nth-child(2) {
    font-size: 1.15rem;
    animation-delay: 0.9s;
  }
  .mascot__zzz i:nth-child(3) {
    font-size: 1.45rem;
    animation-delay: 1.8s;
  }

  /* ---- keyframes ---- */
  @keyframes mascot-pop {
    0% {
      transform: scale(0.72);
      opacity: 0;
    }
    60% {
      transform: scale(1.06);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }
  /* asleep: slow sway + breathing bob */
  @keyframes mascot-doze {
    0%,
    100% {
      transform: rotate(-1.6deg);
    }
    50% {
      transform: rotate(2.2deg) translateY(-7px);
    }
  }
  /* scanning: pans left/right like he's hunting for signals */
  @keyframes mascot-search {
    0%,
    100% {
      transform: translateX(-10px) rotate(-3.5deg);
    }
    22% {
      transform: translateX(-2px) translateY(-5px) rotate(-1deg);
    }
    50% {
      transform: translateX(10px) rotate(3.5deg);
    }
    72% {
      transform: translateX(2px) translateY(-5px) rotate(1deg);
    }
  }
  /* low risk: happy bounce */
  @keyframes mascot-happy {
    0%,
    100% {
      transform: translateY(0) rotate(-1.2deg);
    }
    28% {
      transform: translateY(-12px) rotate(1.6deg) scale(1.02);
    }
    55% {
      transform: translateY(0) rotate(0.4deg);
    }
  }
  /* medium risk: leans in and sizes you up */
  @keyframes mascot-suspect {
    0%,
    100% {
      transform: scale(1);
    }
    35% {
      transform: scale(1.07) translateY(2px);
    }
    55% {
      transform: scale(1.07) translateX(-4px) translateY(2px);
    }
    75% {
      transform: scale(1.07) translateX(4px) translateY(2px);
    }
  }
  @keyframes mascot-zzz {
    0% {
      opacity: 0;
      transform: translate(0, 0) scale(0.7);
    }
    25% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate(16px, -30px) scale(1.25);
    }
  }
  /* high risk: furious trembling, gun trained on you */
  @keyframes mascot-gun {
    0%,
    100% {
      transform: scale(1.04) translate(0, 0);
    }
    15% {
      transform: scale(1.04) translate(-2px, 1px) rotate(-0.8deg);
    }
    30% {
      transform: scale(1.04) translate(2px, -1px) rotate(0.8deg);
    }
    45% {
      transform: scale(1.04) translate(-2px, -1px) rotate(-0.5deg);
    }
    60% {
      transform: scale(1.04) translate(2px, 1px) rotate(0.6deg);
    }
    80% {
      transform: scale(1.04) translate(-1px, 0);
    }
  }
  @keyframes trump-idle {
    0%,
    100% {
      transform: translateY(0) rotate(0.8deg);
    }
    50% {
      transform: translateY(-4px) rotate(-1.2deg);
    }
  }
  @keyframes trump-enter {
    0% {
      opacity: 0;
      transform: translateX(-18px) translateY(10px) scale(0.82);
    }
    72% {
      opacity: 1;
      transform: translateX(3px) translateY(-3px) scale(1.04);
    }
    100% {
      opacity: 1;
      transform: translateX(0) translateY(0) scale(1);
    }
  }
  @keyframes trump-scan {
    0%,
    100% {
      transform: translateX(-3px) rotate(-2deg);
    }
    50% {
      transform: translateX(5px) translateY(-5px) rotate(2deg);
    }
  }
  @keyframes trump-approve {
    0%,
    100% {
      transform: rotate(0.6deg);
    }
    35% {
      transform: translateY(-8px) rotate(-2deg);
    }
    62% {
      transform: translateY(0) rotate(1.4deg);
    }
  }
  @keyframes trump-judge {
    0%,
    100% {
      transform: translateX(0) scale(1);
    }
    40% {
      transform: translateX(-5px) scale(1.04);
    }
    70% {
      transform: translateX(2px) scale(1.04);
    }
  }
  @keyframes trump-fire {
    0%,
    100% {
      transform: scale(1.04) translate(0, 0) rotate(0.5deg);
    }
    20% {
      transform: scale(1.04) translate(2px, -1px) rotate(-0.8deg);
    }
    42% {
      transform: scale(1.04) translate(-2px, 1px) rotate(1deg);
    }
    70% {
      transform: scale(1.04) translate(1px, 0) rotate(-0.4deg);
    }
  }

  @media (max-width: 560px) {
    .mascot {
      width: 190px;
    }
    .mascot[data-reaction='true'] {
      width: min(100%, 292px);
    }
    .mascot__stage {
      height: 196px;
    }
    .mascot__lead {
      width: 168px;
      height: 190px;
      margin-right: 0;
    }
    .mascot[data-reaction='true'] .mascot__lead {
      margin-right: -8px;
    }
    .mascot__fig {
      height: 190px;
    }
    .mascot__trump {
      height: 174px;
      max-width: 44%;
      margin-left: -4px;
    }
    .mascot__shadow {
      width: 112px;
    }
    .mascot[data-reaction='true'] .mascot__shadow {
      width: 205px;
    }
  }
</style>
